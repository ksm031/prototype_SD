```javascript
const engine = Matter.Engine.create();
const render = Matter.Render.create({
  element: document.getElementById('canvas-container'),
  engine: engine,
  options: {
    width: 360,
    height: 560,        // HUD 영역 제외
    wireframes: false,  // 실제 스프라이트 렌더링
    background: '#1a1a2e'
  }
});

// 중력 설정
engine.gravity.y = 1.5; // 기본값 1보다 약간 강하게 (경쾌한 낙하감)

// 바닥 플랫폼 (Static)
