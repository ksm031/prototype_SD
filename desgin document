## 11. 슬로우모션 + 공유 (P1)

```javascript
// 붕괴 감지 시 슬로우모션
function onCollapse() {
  engine.timing.timeScale = 0.15; // 슬로우모션
  setTimeout(() => {
    engine.timing.timeScale = 1.0;
    showResultScreen();
  }, 2000); // 실제 시간 기준 2초 (슬로우모션 중 ~0.3초 게임 시간)
}

// 공유 기능 (P1) — canvas.toBlob()으로 스크린샷 캡처 후 Web Share API
async function shareResult(height, gold) {
  const canvas = document.querySelector('canvas');
  canvas.toBlob(async (blob) => {
    const file = new File([blob], 'stackdungeon.png', { type: 'image/png' });
    if (navigator.share) {
      await navigator.share({
        title: `STACK DUNGEON — ${height}층 달성!`,
        text: `${height}층까지 쌓았다! 골드 ${gold}개 획득 🪙`,
        files: [file]
      });
    }
  });
}
```

