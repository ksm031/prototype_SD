## 9. 골드 및 저장 (P0)

```javascript
// 로컬스토리지 키
const STORAGE_KEYS = {
  gold: 'stackdungeon_gold',
  highscore: 'stackdungeon_highscore',
  deck: 'stackdungeon_deck'
};

// 세션 종료 시 정산
function settle(finalHeight) {
  const earned = Math.max(10, finalHeight * 10); // 최소 10골드 보장
  const current = parseInt(localStorage.getItem(STORAGE_KEYS.gold) || '0');
  localStorage.setItem(STORAGE_KEYS.gold, current + earned);

  const best = parseInt(localStorage.getItem(STORAGE_KEYS.highscore) || '0');
  if (finalHeight > best) {
    localStorage.setItem(STORAGE_KEYS.highscore, finalHeight);
  }
  return earned;
}
```

